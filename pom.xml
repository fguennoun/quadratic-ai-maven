<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!-- ═══════════════════════════════════════════════════════════
         POM PARENT — quadratic-ai (multi-module Maven)
         Coordonnées du projet racine
         ═══════════════════════════════════════════════════════════ -->
    <groupId>ai.quadratic</groupId>
    <artifactId>quadratic-ai</artifactId>
    <version>1.0.0</version>
    <packaging>pom</packaging>

    <name>Quadratic AI — Parent</name>
    <description>
        Projet pédagogique : comprendre le Generative AI en construisant
        une IA locale from scratch pour résoudre des équations du 2ème degré.
    </description>

    <!-- Déclaration des modules enfants -->
    <modules>
        <module>quadratic-core</module>
        <module>quadratic-symbolic</module>
        <module>quadratic-neural</module>
        <module>quadratic-app</module>
    </modules>

    <!-- Propriétés communes à tous les modules -->
    <properties>
        <java.version>21</java.version>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- Versions des dépendances — centralisées ici -->
        <junit.version>5.10.1</junit.version>
        <maven-surefire.version>3.2.2</maven-surefire.version>
        <maven-compiler.version>3.11.0</maven-compiler.version>
        <maven-jar.version>3.3.0</maven-jar.version>
    </properties>

    <!-- Gestion centralisée des dépendances (sans les imposer aux modules) -->
    <dependencyManagement>
        <dependencies>
            <!-- JUnit 5 BOM — importe automatiquement les bons numéros de version -->
            <dependency>
                <groupId>org.junit</groupId>
                <artifactId>junit-bom</artifactId>
                <version>${junit.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <!-- Dépendances inter-modules -->
            <dependency>
                <groupId>ai.quadratic</groupId>
                <artifactId>quadratic-core</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ai.quadratic</groupId>
                <artifactId>quadratic-symbolic</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ai.quadratic</groupId>
                <artifactId>quadratic-neural</artifactId>
                <version>${project.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <!-- Configuration commune des plugins -->
    <build>
        <pluginManagement>
            <plugins>
                <!-- Compilateur Java 21 avec support des preview features -->
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-compiler-plugin</artifactId>
                    <version>${maven-compiler.version}</version>
                    <configuration>
                        <source>${java.version}</source>
                        <target>${java.version}</target>
                        <encoding>UTF-8</encoding>
                    </configuration>
                </plugin>

                <!-- Plugin de test (JUnit 5) -->
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-surefire-plugin</artifactId>
                    <version>${maven-surefire.version}</version>
                    <configuration>
                        <argLine>--enable-preview</argLine>
                    </configuration>
                </plugin>

                <!-- Plugin JAR -->
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-jar-plugin</artifactId>
                    <version>${maven-jar.version}</version>
                </plugin>
            </plugins>
        </pluginManagement>
    </build>
</project>
